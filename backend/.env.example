PORT=3333
NODE_ENV=development

# PostgreSQL — conexão local
DATABASE_URL=postgres://postgres:suasenha@localhost:5432/atendeplus

# PostgreSQL — campos individuais (opcional se usar DATABASE_URL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=atendeplus
# DB_USER=postgres
# DB_PASSWORD=suasenha

# JWT — use uma string longa e aleatória em produção
JWT_SECRET=troque_por_uma_chave_secreta_bem_longa_e_aleatoria

# URL do frontend (para liberar CORS em produção)
# FRONTEND_URL=https://seu-app.vercel.app

# Dados do usuário administrador (usado pelo seed)
ADMIN_EMAIL=developerwesleymelo@gmail.com
ADMIN_PASSWORD=adm123
ADMIN_NOME=Wesley Melo
